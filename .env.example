GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key

# Optional model overrides
GEMINI_SUMMARY_MODEL=gemini-3.1-flash-lite
GEMINI_QUIZ_MODEL=gemini-3.1-pro-preview
GEMINI_TRANSCRIPT_FALLBACK_MODEL=gemini-3-flash-preview
GEMINI_TRANSCRIPT_CLEANUP_MODEL=gemini-3.1-flash-lite

# Google Cloud Speech-to-Text V2 Chirp 3
GOOGLE_APPLICATION_CREDENTIALS=D:\Study\IT\python\Final_Project\google-service-account.json
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
GOOGLE_CLOUD_LOCATION=asia-southeast1
GOOGLE_SPEECH_MODEL=chirp_3
GOOGLE_SPEECH_LANGUAGE=vi-VN

# Audio preprocessing
AUDIO_CHUNK_SECONDS=45
MAX_AUDIO_FILE_SIZE_MB=200
